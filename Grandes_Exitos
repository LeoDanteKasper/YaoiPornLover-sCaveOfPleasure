```html
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Grandes Éxitos - Mugen Edits</title>
    <style>
        /* ==========================================================================
           VARIABLES & RESETS
           ========================================================================== */
        :root {
            --bg-dark: #070604;
            --card-bg: rgba(22, 18, 10, 0.75);
            --gold-primary: #ffd700;
            --gold-secondary: #d4af37;
            --gold-dark: #7a5c00;
            --gold-glow: rgba(255, 215, 0, 0.25);
            --gold-border: rgba(212, 175, 55, 0.35);
            --text-main: #f5e9c9;
            --text-muted: #a39572;
            --font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background-color: var(--bg-dark);
            background-image: 
                radial-gradient(circle at 50% 0%, rgba(212, 175, 55, 0.08) 0%, transparent 60%),
                radial-gradient(circle at 80% 80%, rgba(122, 92, 0, 0.05) 0%, transparent 50%);
            color: var(--text-main);
            font-family: var(--font-family);
            min-height: 100vh;
            padding: 2rem 1rem;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        /* ==========================================================================
           HEADER & CATEGORY FILTER
           ========================================================================== */
        .header-title {
            text-align: center;
            margin-bottom: 2rem;
        }

        .header-title h1 {
            font-size: 2.5rem;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 3px;
            background: linear-gradient(135deg, #fff 0%, var(--gold-primary) 50%, var(--gold-dark) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-shadow: 0 0 20px var(--gold-glow);
            margin-bottom: 0.5rem;
        }

        .header-title p {
            color: var(--text-muted);
            font-size: 0.95rem;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        /* BARRA DE FILTROS */
        .filter-container {
            display: flex;
            gap: 1rem;
            margin-bottom: 2.5rem;
            flex-wrap: wrap;
            justify-content: center;
        }

        .filter-btn {
            background: rgba(22, 18, 10, 0.8);
            border: 1px solid var(--gold-border);
            color: var(--gold-secondary);
            padding: 0.6rem 1.4rem;
            border-radius: 30px;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            font-size: 0.85rem;
            cursor: pointer;
            backdrop-filter: blur(8px);
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            box-shadow: 0 4px 15px rgba(0,0,0,0.4);
        }

        .filter-btn:hover, .filter-btn.active {
            background: linear-gradient(135deg, var(--gold-primary) 0%, var(--gold-secondary) 100%);
            color: var(--bg-dark);
            border-color: var(--gold-primary);
            box-shadow: 0 0 15px var(--gold-glow);
            transform: scale(1.05);
        }

        /* ==========================================================================
           GRID SYSTEM & CARDS
           ========================================================================== */
        .cards-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 320px));
            gap: 2rem;
            width: 100%;
            max-width: 1300px;
            justify-content: center;
        }

        .edit-card {
            background: var(--card-bg);
            border: 1px solid var(--gold-border);
            border-radius: 16px;
            overflow: hidden;
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.6), inset 0 0 1px rgba(255, 215, 0, 0.2);
            transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1), 
                        border-color 0.4s ease, 
                        box-shadow 0.4s ease,
                        opacity 0.4s ease;
            display: flex;
            flex-direction: column;
            opacity: 1;
        }

        .edit-card.hidden {
            display: none;
            opacity: 0;
        }

        .edit-card:hover {
            transform: translateY(-8px);
            border-color: var(--gold-primary);
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.8), 0 0 25px var(--gold-glow);
        }

        /* ==========================================================================
           VISUAL CONTAINER (GIFS STAND & RANDOM POSE)
           ========================================================================== */
        .visual-container {
            position: relative;
            width: 100%;
            height: 340px;
            background: radial-gradient(circle, #1a150b 0%, #0d0a05 100%);
            border-bottom: 1px solid var(--gold-border);
            overflow: hidden;
            cursor: pointer;
        }

        .stand-layer {
            position: absolute;
            inset: 0;
            display: flex;
            justify-content: space-evenly;
            align-items: flex-end;
            padding-bottom: 10px;
            transition: opacity 0.3s ease;
            z-index: 1;
        }

        .stand-layer img {
            max-height: 85%;
            max-width: 45%;
            object-fit: contain;
            filter: drop-shadow(0 0 8px rgba(0,0,0,0.8));
        }

        .pose-layer {
            position: absolute;
            inset: 0;
            display: flex;
            justify-content: center;
            align-items: flex-end;
            padding-bottom: 10px;
            opacity: 0;
            transition: opacity 0.3s ease;
            z-index: 2;
        }

        .pose-layer img {
            max-height: 90%;
            max-width: 90%;
            object-fit: contain;
            filter: drop-shadow(0 0 12px var(--gold-glow));
        }

        .visual-container:hover .stand-layer {
            opacity: 0;
        }

        .visual-container:hover .pose-layer {
            opacity: 1;
        }

        /* ==========================================================================
           BODY CONTENT & LORE
           ========================================================================== */
        .card-body {
            padding: 1.25rem;
            display: flex;
            flex-direction: column;
            flex-grow: 1;
        }

        .card-author {
            color: var(--gold-primary);
            font-size: 0.85rem;
            font-weight: 700;
            letter-spacing: 0.5px;
            margin-bottom: 0.5rem;
            display: block;
        }

        .card-title {
            color: #fff;
            font-size: 1.2rem;
            font-weight: 800;
            margin-bottom: 0.75rem;
            line-height: 1.2;
        }

        .card-lore {
            color: var(--text-muted);
            font-size: 0.88rem;
            line-height: 1.5;
            margin-bottom: 1.25rem;
            flex-grow: 1;
            white-space: pre-line;
            border-top: 1px solid rgba(212, 175, 55, 0.1);
            padding-top: 0.75rem;
        }

        /* ==========================================================================
           HASHTAGS / TAGS
           ========================================================================== */
        .tags-container {
            display: flex;
            flex-wrap: wrap;
            gap: 0.4rem;
        }

        .tag-pill {
            background: rgba(122, 92, 0, 0.2);
            border: 1px solid var(--gold-border);
            color: var(--gold-secondary);
            font-size: 0.75rem;
            font-weight: 600;
            padding: 0.25rem 0.6rem;
            border-radius: 6px;
            text-decoration: none;
            transition: all 0.2s ease;
        }

        .tag-pill:hover {
            background: var(--gold-primary);
            color: var(--bg-dark);
            border-color: var(--gold-primary);
            box-shadow: 0 0 10px var(--gold-glow);
        }
    </style>
</head>
<body>

    <header class="header-title">
        <h1>Grandes Éxitos</h1>
        <p>Mugen Yaoi & Bara Sprite Edits</p>
    </header>

    <!-- Botones de Filtrado por Categoría -->
    <div class="filter-container">
        <button class="filter-btn active" onclick="filterCategory('all')">Todos</button>
        <button class="filter-btn" onclick="filterCategory('fnf')">FNF</button>
        <button class="filter-btn" onclick="filterCategory('lolcow')">Lolcow</button>
    </div>

    <!-- Contenedor del Grid -->
    <main class="cards-grid" id="cardsGrid"></main>

    <script>
        /**
         * ARRAY DE DATOS CON CATEGORÍAS DEFINIDAS
         */
        const editsData = [
            {
                id: "senpai-fnf",
                category: "fnf",
                author: "@YeyoEdits",
                title: "Senpai (FNF) - Bara Edition",
                standGifs: [
                    "https://placehold.co/120x200/121008/FFD700.gif?text=Senpai+Stand+1",
                    "https://placehold.co/120x200/121008/FFD700.gif?text=Senpai+Stand+2"
                ],
                poseGifs: [
                    "https://archive.org/download/e_20260721/ea%20%281%29.gif",
                    "https://archive.org/download/e_20260721/ea%20%284%29.gif"
                ],
                lore: "Reconstrucción completa de las proporciones de Senpai para el motor MUGEN. Pasó de su estilo vectorial escolar a una contextura muscular pesada, conservando sus expresiones de conquista.",
                hashtags: ["#FNF", "#Senpai", "#BaraMugen", "#SpriteEdit"]
            },
            {
                id: "doomentio-lolcow",
                category: "lolcow",
                author: "@YeyoEdits",
                title: "Doomentio - Overlord Custom",
                standGifs: [
                    "https://ia800104.us.archive.org/29/items/el-diente/EA%20%282%29.webp",
                    "https://ia800104.us.archive.org/29/items/el-diente/EA%20%282%29.webp"
                ],
                poseGifs: [
                    "https://archive.org/download/e_20260721/ea%20%283%29.gif",
                    "https://archive.org/download/e_20260721/ea%20%282%29.gif"
                ],
                lore: "Edit de MUGEN basado en la estética del Perezoso Doom. Rediseño de hitboxes, animaciones de ataque con auras doradas y sprites ajustados a estilo Bara.",
                hashtags: ["#Lolcow", "#Doomentio", "#MugenCustom", "#YaoiBara"]
            }
        ];

        /**
         * RENDERIZADO DINÁMICO
         */
        function renderCards() {
            const container = document.getElementById('cardsGrid');
            container.innerHTML = '';

            editsData.forEach((data) => {
                const card = document.createElement('article');
                card.className = `edit-card category-${data.category}`;
                card.setAttribute('data-category', data.category);

                const tagsHTML = data.hashtags.map(tag => `<span class="tag-pill">${tag}</span>`).join('');

                card.innerHTML = `
                    <div class="visual-container" id="visual-${data.id}">
                        <div class="stand-layer">
                            <img src="${data.standGifs[0]}" alt="Stand Left">
                            <img src="${data.standGifs[1]}" alt="Stand Right">
                        </div>
                        <div class="pose-layer">
                            <img id="pose-img-${data.id}" src="${data.poseGifs[0]}" alt="Pose GIF">
                        </div>
                    </div>
                    <div class="card-body">
                        <span class="card-author">${data.author}</span>
                        <h2 class="card-title">${data.title}</h2>
                        <p class="card-lore">${data.lore}</p>
                        <div class="tags-container">
                            ${tagsHTML}
                        </div>
                    </div>
                `;

                container.appendChild(card);

                // Lógica de Hover para el GIF Aleatorio
                const visualBox = card.querySelector(`#visual-${data.id}`);
                const poseImg = card.querySelector(`#pose-img-${data.id}`);

                visualBox.addEventListener('mouseenter', () => {
                    const randomIndex = Math.floor(Math.random() * data.poseGifs.length);
                    poseImg.src = data.poseGifs[randomIndex];
                });
            });
        }

        /**
         * FILTRADO POR CATEGORÍA
         */
        function filterCategory(category) {
            // Actualizar botones
            const buttons = document.querySelectorAll('.filter-btn');
            buttons.forEach(btn => btn.classList.remove('active'));
            event.target.classList.add('active');

            // Filtrar las tarjetas
            const cards = document.querySelectorAll('.edit-card');
            cards.forEach(card => {
                const cardCategory = card.getAttribute('data-category');
                if (category === 'all' || cardCategory === category) {
                    card.classList.remove('hidden');
                } else {
                    card.classList.add('hidden');
                }
            });
        }

        // Inicializar la vista
        document.addEventListener('DOMContentLoaded', renderCards);
    </script>
</body>
</html>

